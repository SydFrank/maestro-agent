# ===== LLM 提供商 =====
# 主模型：Claude Opus 4.8
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-8

# 备选：OpenAI（可留空）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# 默认使用的提供商：anthropic | openai
LLM_PROVIDER=anthropic

# ===== 数据库 =====
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_pwd
POSTGRES_DB=agent_platform
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ===== Redis =====
REDIS_URL=redis://redis:6379/0

# ===== 安全 =====
JWT_SECRET=change-me-in-prod-please-use-a-long-random-string
JWT_EXPIRE_MINUTES=120

# ===== 服务内部地址（docker-compose 网络） =====
LLM_GATEWAY_URL=http://llm-gateway:8000
RAG_SERVICE_URL=http://rag-service:8000
SANDBOX_RUNNER_URL=http://sandbox-runner:8000
AGENT_CORE_URL=http://agent-core:8000

# ===== 可观测 =====
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO
